# Zerodha Kite Connect
KITE_API_KEY=
KITE_API_SECRET=

# Optional fallback only. Prefer dashboard login, which stores the daily token in DATA_ROOT/secrets.
KITE_ACCESS_TOKEN=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App storage
# Local default: data
# Railway recommended with Volume mounted at /app/data: /app/data
DATA_ROOT=data

# Optional dashboard access guard.
# If set, dashboard requires this value through ?token=... until proper auth is added.
DASHBOARD_TOKEN=

# Supabase backend storage for NSE large deals.
# Use only on backend/server. Never expose service-role keys in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_LARGE_DEALS_TABLE=nse_large_deals
